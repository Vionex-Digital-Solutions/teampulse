# Database — SQLite for local dev, PostgreSQL for later
DATABASE_URL=sqlite+aiosqlite:///./teampulse.db
# DATABASE_URL=postgresql+asyncpg://teampulse:teampulse_local@localhost:5432/teampulse

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (JSON array of allowed origins)
ALLOWED_ORIGINS=["http://localhost:3000"]

# Application
ENVIRONMENT=development
DEBUG=false
